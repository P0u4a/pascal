# FastAPI hub bind address.
HUB_BIND_ADDR=0.0.0.0:8080

# URL compiled into the Swift app. Use the Mac's LAN IP for a real iPhone.
HUB_IOS_SERVER_URL=http://<hub-ip>:8080

# Robot movement bridge. The hub POSTs F/B/L/R as bytes 0x01/0x02/0x03/0x04.
ESP_HTTP_URL=http://<esp-ip>/motion
ESP_MOVE_STEP_MS=700

# Snapshot storage. Defaults to /tmp/pascal/latest.jpg.
# HUB_DATA_DIR=/tmp/pascal
# HUB_SNAPSHOT_PATH=/tmp/pascal/latest.jpg

# Optional ESP log forwarding target for PlatformIO builds.
# HUB_LOG_URL=http://<hub-ip>:8080/v1/logs
